# BuildIQ — environment variable template
# Copy to .env and fill in real values

# Anthropic Claude API key (required for AI features)
ANTHROPIC_API_KEY=your_key_here

# JWT signing secrets — generate with: openssl rand -hex 32
SECRET_KEY=generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32

# SQLite database path
DATABASE_URL=sqlite:///backend/db/buildiq.db

# Frontend origin (used in CORS)
FRONTEND_URL=https://your-vercel-url.vercel.app
FRONTEND_URL_2=

# WhatsApp notifications via WATI (optional)
WATI_API_TOKEN=
WATI_API_URL=

# Set False in production
DEBUG=False
